{
  "manifest_version": 3,
  "name": "Syllabus Helper",
  "version": "1.0.0",
  "description": "Upload syllabi, view deadlines, ask questions, manage grades.",
  "permissions": ["activeTab", "contextMenus", "storage", "scripting", "tabs"],
  "host_permissions": ["https://syllabushelper.net/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instructure.com/*", "*://*.brightspace.com/*", "https://syllabushelper.net/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
